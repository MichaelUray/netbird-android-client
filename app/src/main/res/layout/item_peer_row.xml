<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/peer_row_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/peer_status_badge"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/peer_status_badge"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/text_peer_fqdn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/nb_txt"
            android:textSize="15sp"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/text_peer_ip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/nb_txt_light"
            android:textSize="13sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/peer_row_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_peer_conn_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/nb_txt_light"
            android:textSize="13sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nb_gray_separator" />

</LinearLayout>
